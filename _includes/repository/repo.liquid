<div class="repo p-2 mb-3" style="width: 48%;">
  <a href="https://github.com/{{ include.repository.repo }}" target="_blank">
    <strong>{{ include.repository.repo }}</strong>
  </a>
  {% if include.repository.description %}
    <p class="text-muted mb-0">{{ include.repository.description }}</p>
  {% endif %}
</div>